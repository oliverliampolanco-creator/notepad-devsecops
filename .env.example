# ============================================================
# [SEC-10] SECRETOS FUERA DEL CÓDIGO — NUNCA commitear .env
# ============================================================
# Copia este archivo como .env y llena los valores reales.
# Agrega .env a tu .gitignore !

# ── Flask ──
FLASK_ENV=development        # Cambiar a "production" en Render
SECRET_KEY=CAMBIA-ESTO-AHORA-genera-un-valor-aleatorio-largo
JWT_SECRET=CAMBIA-ESTO-TAMBIEN-otro-valor-aleatorio-diferente

# ── Base de datos ──
# SQLite local:
DATABASE_URL=sqlite:///notepad.db
# PostgreSQL en producción (Render te da este string):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Admin por defecto (se crea al iniciar si no existe) ──
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=CambiaEstaContraseña@2024!

# ── CORS ── (en producción pon tu URL de Render)
ALLOWED_ORIGINS=http://localhost:5000,https://tu-app.onrender.com

# ── Puerto ──
PORT=5000
